NODE_ENV=production
APP_HOST=127.0.0.1
APP_PORT=12000
APP_URL=http://127.0.0.1:12000
DATABASE_URL=postgresql://newsuser:password@localhost:5432/newsstudio
SESSION_SECRET=
ENCRYPTION_KEY=
OBS_EXECUTABLE=/usr/bin/obs
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=
OBS_PROFILE_NAME=Automated News Studio
OBS_SCENE_COLLECTION=Automated News Studio
OBS_AUTO_START=true
OBS_AUTO_RESTART=true
STREAM_AUTO_START=false
STREAM_SERVICE=custom
STREAM_SERVER=
STREAM_KEY=
VIDEO_BASE_WIDTH=1920
VIDEO_BASE_HEIGHT=1080
VIDEO_OUTPUT_WIDTH=1920
VIDEO_OUTPUT_HEIGHT=1080
VIDEO_FPS=30
VIDEO_BITRATE_KBPS=6000
AUDIO_BITRATE_KBPS=160
TTS_ENGINE=piper
TTS_MODEL_PATH=
TTS_OUTPUT_DIRECTORY=./var/tts
TTS_DEFAULT_VOICE=
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
NEWS_DEFAULT_FETCH_INTERVAL=900
NEWS_MAX_ARTICLE_SIZE_MB=5
NEWS_MAX_IMAGE_SIZE_MB=10
NEWS_USER_AGENT=AutomatedNewsStudio/1.0
MEDIA_DIRECTORY=./var/media
MEDIA_RETENTION_DAYS=30
BACKUP_DIRECTORY=./var/backups
LOG_LEVEL=info
ALLOW_PRIVATE_SOURCES=false
