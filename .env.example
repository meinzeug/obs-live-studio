# Lokale Geheimnisse und DATABASE_URL werden durch node scripts/configure-env.mjs erzeugt.
NODE_ENV=production
APP_HOST=127.0.0.1
APP_PORT=12000
APP_URL=http://127.0.0.1:12000
PUBLIC_APP_URL=http://127.0.0.1:12000
# Zusätzliche Browser-Origins für credentialed /api-Aufrufe, kommagetrennt und ohne Pfad.
CORS_ALLOWED_ORIGINS=
ALLOW_REMOTE_BIND=false
PREFLIGHT_DATABASE_ATTEMPTS=5
PREFLIGHT_DATABASE_DELAY_MS=1000
OBS_EXECUTABLE=/usr/bin/obs
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PROFILE_NAME=Automated News Studio
OBS_SCENE_COLLECTION=Automated News Studio
OBS_AUTO_START=true
OBS_AUTO_RESTART=true
OBS_CLEAR_CRASH_SENTINELS=true
OBS_STALE_ARTIFACT_MIN_AGE_MS=1000
OBS_BROWSER_HW_ACCEL=false
OBS_ARGS_JSON=
DESKTOP_AGENT_URL=http://127.0.0.1:12090
DESKTOP_AGENT_HOST=127.0.0.1
DESKTOP_AGENT_PORT=12090
STREAM_AUTO_START=false
STREAM_AUTO_RESTART=true
STREAM_SUPERVISOR_INTERVAL_MS=15000
STREAM_SUPERVISOR_MAX_BACKOFF_MS=300000
STREAM_START_TIMEOUT_MS=15000
BROADCAST_RESTORE_MODE=resume
CHANNEL_NAME=ArgumentationsKette
YOUTUBE_CHANNEL_URL=
STREAM_SERVICE=youtube
STREAM_SERVER=rtmps://a.rtmps.youtube.com:443/live2
TWITCH_ENABLED=false
TWITCH_CHANNEL_URL=
TWITCH_STREAM_SERVER=rtmps://live.twitch.tv:443/app
OBS_MULTI_RTMP_RELEASE=latest
OBS_MULTI_RTMP_FORCE_INSTALL=false
OBS_MULTI_RTMP_PLUGIN_PATH=
VIDEO_BASE_WIDTH=1920
VIDEO_BASE_HEIGHT=1080
VIDEO_OUTPUT_WIDTH=1920
VIDEO_OUTPUT_HEIGHT=1080
VIDEO_FPS=30
VIDEO_BITRATE_KBPS=6000
AUDIO_BITRATE_KBPS=160
FFMPEG_EXECUTABLE=ffmpeg
TTS_ENGINE=piper
TTS_MODEL_PATH=./var/models/piper/de_DE-thorsten-high.onnx
PIPER_MODEL_PATH=./var/models/piper/de_DE-thorsten-high.onnx
PIPER_EXECUTABLE=./var/piper-venv/bin/piper
TTS_OUTPUT_DIR=./var/tts
TTS_OUTPUT_DIRECTORY=./var/tts
TTS_DEFAULT_VOICE=de_DE-thorsten-high
TTS_SPEED=1
TTS_VOLUME=1
TTS_TIMEOUT_MS=120000
ESPEAK_EXECUTABLE=/usr/bin/espeak-ng
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
NEWS_DEFAULT_FETCH_INTERVAL=900
NEWS_MAX_ARTICLE_SIZE_MB=5
NEWS_MAX_IMAGE_SIZE_MB=10
NEWS_USER_AGENT=AutomatedNewsStudio/1.0
AUTOPILOT_ENABLED=false
AUTOPILOT_MIN_TRUST=80
AUTOPILOT_REQUIRE_STREAM=true
AUTOPILOT_SOURCE_IDS=
AUTOPILOT_SCAN_LIMIT=100
MEDIA_DIRECTORY=./var/media
MEDIA_RETENTION_DAYS=30
BACKUP_DIRECTORY=./var/backups
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_MEDIA=true
BACKUP_MAX_AGE_HOURS=36
BACKUP_REHEARSAL_MAX_AGE_HOURS=216
LOG_LEVEL=info
RATE_LIMIT_MAX=600
ALLOW_PRIVATE_SOURCES=false
