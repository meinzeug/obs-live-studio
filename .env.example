# Lokale Geheimnisse und DATABASE_URL werden durch node scripts/configure-env.mjs erzeugt.
NODE_ENV=production
APP_HOST=127.0.0.1
APP_PORT=12000
WEB_PORT=12001
APP_URL=http://127.0.0.1:12000
PUBLIC_APP_URL=http://127.0.0.1:12000
# Zusätzliche Browser-Origins für credentialed /api-Aufrufe, kommagetrennt und ohne Pfad.
CORS_ALLOWED_ORIGINS=
ALLOW_REMOTE_BIND=false
PREFLIGHT_DATABASE_ATTEMPTS=5
PREFLIGHT_DATABASE_DELAY_MS=1000
OBS_EXECUTABLE=/usr/bin/obs
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PROFILE_NAME=Open TV Studio
OBS_SCENE_COLLECTION=Open TV Studio
OBS_AUTO_START=true
OBS_AUTO_RESTART=true
OBS_CLEAR_CRASH_SENTINELS=true
OBS_STALE_ARTIFACT_MIN_AGE_MS=1000
OBS_BROWSER_HW_ACCEL=false
OBS_ARGS_JSON=
DESKTOP_AGENT_URL=http://127.0.0.1:12090
DESKTOP_AGENT_HOST=127.0.0.1
DESKTOP_AGENT_PORT=12090
STREAM_AUTO_START=false
STREAM_AUTO_RESTART=true
STREAM_SUPERVISOR_INTERVAL_MS=15000
STREAM_SUPERVISOR_MAX_BACKOFF_MS=300000
STREAM_START_TIMEOUT_MS=15000
BROADCAST_RESTORE_MODE=resume
BROADCAST_RUNNER_OBS_RECONNECT_MS=5000

# Individuelles Studio- und Kanalprofil
STUDIO_NAME=Open TV Studio
CHANNEL_NAME=Mein Kanal
CHANNEL_LOGO_PATH=
CHANNEL_LOGO_MIME=
CHANNEL_LOGO_SHA256=
CHANNEL_LOGO_ENABLED=true
CHANNEL_LOGO_VISIBILITY=always
CHANNEL_LOGO_POSITION=top-right
CHANNEL_LOGO_WIDTH=180
CHANNEL_LOGO_OPACITY=92
CHANNEL_LOGO_MARGIN=42
CHANNEL_URL=

# Live-Portal für Smartphone-/Webkamera-Zuschaltungen.
# LIVE_PORTAL_SERVICE_TOKEN muss ein zufälliges Secret sein und darf nie ins Browser-Bundle.
LIVE_PORTAL_BASE_URL=https://obs.meinzeug.cloud
LIVE_PORTAL_SERVICE_TOKEN=
LIVE_PORTAL_TIMEOUT_MS=8000

# Hauptausgabe: youtube, twitch, x, rumble, kick, facebook, linkedin oder custom
# YouTube-Standardserver: rtmps://a.rtmps.youtube.com:443/live2
# Twitch-Standardserver: rtmps://live.twitch.tv:443/app
# Für X, Rumble, Kick, Facebook, LinkedIn und custom den Server aus dem jeweiligen Creator-Dashboard eintragen.
STREAM_PLATFORM=custom
STREAM_TARGET_NAME=Hauptziel
STREAM_SERVER=
STREAM_KEY=
STREAM_REQUIRE_RTMPS=true

# Zusätzliche synchrone Ziele als JSON-Array. Schlüssel sollten über keyEnv referenziert werden.
# Beispiel:
# STREAM_TARGETS_JSON=[{"id":"rumble","platform":"rumble","name":"Rumble","serverEnv":"RUMBLE_STREAM_SERVER","keyEnv":"RUMBLE_STREAM_KEY","channelUrlEnv":"RUMBLE_CHANNEL_URL"}]
STREAM_TARGETS_JSON=[]
RUMBLE_STREAM_SERVER=
RUMBLE_STREAM_KEY=
RUMBLE_CHANNEL_URL=
X_STREAM_SERVER=
X_STREAM_KEY=
X_CHANNEL_URL=
KICK_STREAM_SERVER=
KICK_STREAM_KEY=
KICK_CHANNEL_URL=
FACEBOOK_STREAM_SERVER=
FACEBOOK_STREAM_KEY=
FACEBOOK_CHANNEL_URL=
LINKEDIN_STREAM_SERVER=
LINKEDIN_STREAM_KEY=
LINKEDIN_CHANNEL_URL=

# Abwärtskompatibilität für bestehende YouTube-/Twitch-Installationen
YOUTUBE_CHANNEL_URL=
TWITCH_ENABLED=false
TWITCH_CHANNEL_URL=
TWITCH_STREAM_SERVER=rtmps://live.twitch.tv:443/app
TWITCH_STREAM_KEY=
STREAM_SERVICE=custom

OBS_MULTI_RTMP_RELEASE=latest
OBS_MULTI_RTMP_FORCE_INSTALL=false
OBS_MULTI_RTMP_PLUGIN_PATH=
VIDEO_BASE_WIDTH=1920
VIDEO_BASE_HEIGHT=1080
VIDEO_OUTPUT_WIDTH=1920
VIDEO_OUTPUT_HEIGHT=1080
VIDEO_FPS=30
VIDEO_BITRATE_KBPS=6000
AUDIO_BITRATE_KBPS=160
FFMPEG_EXECUTABLE=ffmpeg
FFPROBE_EXECUTABLE=ffprobe
TTS_ENGINE=pocket-tts
TTS_PRESET_ID=pocket-tts-german-24l-lola
TTS_MODEL_PATH=./var/models/piper/de_DE-dii-high.onnx
PIPER_MODEL_PATH=./var/models/piper/de_DE-dii-high.onnx
PIPER_EXECUTABLE=./var/piper-venv/bin/piper
TTS_OUTPUT_DIR=./var/tts
TTS_OUTPUT_DIRECTORY=./var/tts
TTS_DEFAULT_VOICE=lola
POCKET_TTS_SERVER_URL=http://127.0.0.1:8000
POCKET_TTS_LANGUAGE=german_24l
POCKET_TTS_VOICE=lola
POCKET_TTS_TEMPERATURE=0.7
POCKET_TTS_DECODE_STEPS=4
POCKET_TTS_EXECUTABLE=./var/pocket-tts-venv/bin/pocket-tts
# Eigene Pocket-TTS-Stimme für Chatmoderatorin Mia/mod2 im YouTube-Einordnungsformat.
AI_CHAT_MODERATOR_TTS_VOICE=alba
TTS_SPEED=1
TTS_VOLUME=1
TTS_OUTPUT_GAIN_DB=7
TTS_TIMEOUT_MS=120000
AI_HOST_AVATAR_VIDEO_PATHS=./var/media/ai-host/ava-moderator-1.webm,./var/media/ai-host/ava-moderator-2.webm,./var/media/ai-host/ava-moderator-3.webm
AI_HOST_AVATAR_VIDEO_PATH=./var/media/ai-host/ava-moderator-1.webm
YOUTUBE_CONTEXT_AVATAR_IDLE_PATH=./var/media/ai-host/youtube-context-idle.webm
YOUTUBE_CONTEXT_AVATAR_SPEAKING_PATH=./var/media/ai-host/youtube-context-speaking.webm
YOUTUBE_CONTEXT_CHAT_MODERATOR_PATH=./var/media/ai-host/youtube-context-chat-moderator.webm
# Markenfilm: Wartungshintergrund, Hintergrund der YouTube-Einordnung und einmaliges Intro je Sendung.
STUDIO_BRAND_VIDEO_PATH=./var/media/studio/zeitkante-intro-outro.mp4
PROGRAM_INTRO_ENABLED=true
PROGRAM_INTRO_DURATION_MS=8000
AI_HOST_DUCK_YOUTUBE_VOLUME=0.22
YTDLP_EXECUTABLE=./var/youtube-tools-venv/bin/yt-dlp
YTDLP_POT_PROVIDER_HOME=./var/bgutil-ytdlp-pot-provider/server
# Optionales dediziertes Browserprofil, wenn YouTube anonyme Transkriptzugriffe blockiert (z. B. chrome:Default).
YTDLP_COOKIES_FROM_BROWSER=
ESPEAK_EXECUTABLE=/usr/bin/espeak-ng
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
# OpenRouter wird über Einstellungen → OpenRouter verwaltet. Der Key bleibt ausschließlich in der privaten .env.
OPENROUTER_API_KEY=
OPENROUTER_PAID_FALLBACK=true
OPENROUTER_AUTO_PROCESS_INGEST=true
# deny schließt Provider aus, die Anfragen zur Datensammlung verwenden dürfen.
OPENROUTER_DATA_COLLECTION=deny
# Der Free-Router benötigt für Ava häufig teilnehmende Free-Anbieter. Nur öffentliche Chatfragen
# und das geprüfte Quellenpaket werden dafür gesendet; Paid-Fallbacks bleiben technisch gesperrt.
OPENROUTER_FREE_CHAT_DATA_COLLECTION=allow
OPENROUTER_TIMEOUT_MS=60000
OPENROUTER_RATE_LIMIT_PER_MINUTE=30
OPENROUTER_APP_NAME=OBS Live Studio
NEWS_DEFAULT_FETCH_INTERVAL=900
NEWS_MAX_ARTICLE_SIZE_MB=5
NEWS_MAX_IMAGE_SIZE_MB=10
NEWS_USER_AGENT=OpenTVStudio/1.0
AUTOPILOT_ENABLED=false
AUTOPILOT_MIN_TRUST=80
AUTOPILOT_REQUIRE_STREAM=true
AUTOPILOT_REQUIRE_VIDEO=true
AUTOPILOT_SHOW_ITEM_COUNT=1
AUTOPILOT_PAUSE_SECONDS=5
AUTOPILOT_PAUSE_BETWEEN_SHOWS_SECONDS=15
AUTOPILOT_SOURCE_IDS=
AUTOPILOT_SCAN_LIMIT=100

# Aktive Medienrecherche pro Beitrag. Wikimedia Commons funktioniert ohne Schlüssel.
MEDIA_COMMONS_ENABLED=true
WIKIMEDIA_USER_AGENT=OpenTVStudio/1.0 (lokales Nachrichtenstudio)
PEXELS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_DATA_API_KEY=
MEDIA_AI_ENABLED=false
MEDIA_AUTO_IMPORT_VIDEO=true
MEDIA_AUTO_IMPORT_GRAPHIC=true
MEDIA_DISCOVERY_MAX_CANDIDATES=30
MEDIA_DOWNLOAD_TIMEOUT_MS=120000
MEDIA_MAX_VIDEO_BYTES=262144000
MEDIA_MAX_IMAGE_BYTES=15728640
MEDIA_MAX_VIDEO_DURATION_SECONDS=180
MEDIA_DIRECTORY=./var/media
MEDIA_UPLOAD_DIR=./var/media
MEDIA_RETENTION_DAYS=30

BACKUP_DIRECTORY=./var/backups
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_MEDIA=true
BACKUP_MAX_AGE_HOURS=36
BACKUP_REHEARSAL_MAX_AGE_HOURS=216
LOG_LEVEL=info
RATE_LIMIT_MAX=600
ALLOW_PRIVATE_SOURCES=false
