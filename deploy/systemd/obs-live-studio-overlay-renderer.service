[Unit]
Description=OBS Live Studio Overlay Renderer
After=obs-live-studio-api.service
Requires=obs-live-studio-api.service

[Service]
Type=simple
WorkingDirectory=%h/obs-live-studio
EnvironmentFile=%h/obs-live-studio/.env
Environment=NODE_ENV=production
ExecStart=/bin/bash -lc '[[ ! -s "$HOME/.nvm/nvm.sh" ]] || source "$HOME/.nvm/nvm.sh"; exec npm run start -w @ans/overlay-renderer'
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
