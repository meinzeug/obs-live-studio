{
  "name": "automated-news-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "dev": "concurrently \"npm run dev -w @ans/api\" \"npm run dev -w @ans/web\" \"npm run dev -w @ans/overlay-renderer\"",
    "db:migrate": "node --env-file=.env packages/database/dist/migrate.js",
    "db:seed": "node --env-file=.env packages/database/dist/seed.js",
    "obs:configure": "node --env-file=.env scripts/configure-obs.mjs && node --env-file=.env scripts/configure-obs-multi-rtmp.mjs",
    "obs:install-multi-rtmp": "node --env-file=.env scripts/install-obs-multi-rtmp.mjs",
    "obs:reset-youtube": "node --env-file=.env scripts/reset-obs-youtube-auth.mjs",
    "studio:bootstrap": "node --env-file=.env scripts/bootstrap-local.mjs",
    "studio:verify": "node --env-file=.env scripts/verify-local-broadcast.mjs",
    "studio:set-admin": "node --env-file=.env scripts/set-local-admin.mjs",
    "studio:sources": "node --env-file=.env scripts/configure-official-sources.mjs",
    "ci": "node scripts/ci-run.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "obs:mock": "tsx scripts/start-obs-mock.mjs",
    "ci:runtime": "node scripts/ci-run.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "latest",
    "@fastify/cors": "latest",
    "@fastify/helmet": "latest",
    "@fastify/multipart": "latest",
    "@fastify/rate-limit": "latest",
    "@fastify/websocket": "latest",
    "@vitejs/plugin-react": "latest",
    "argon2": "latest",
    "cheerio": "latest",
    "dotenv": "latest",
    "fast-xml-parser": "latest",
    "fastify": "latest",
    "feedparser": "latest",
    "ioredis": "latest",
    "ipaddr.js": "latest",
    "jose": "latest",
    "lucide-react": "latest",
    "nanoid": "latest",
    "obs-websocket-js": "latest",
    "pg": "latest",
    "pino": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1",
    "undici": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "autoprefixer": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "postcss": "latest",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
