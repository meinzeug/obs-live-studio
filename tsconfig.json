{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ans/shared-types": ["packages/shared-types/src/index.ts"],
      "@ans/security": ["packages/security/src/index.ts"],
      "@ans/news-parser": ["packages/news-parser/src/index.ts"],
      "@ans/content-processing": ["packages/content-processing/src/index.ts"],
      "@ans/ai-provider": ["packages/ai-provider/src/index.ts"],
      "@ans/obs-controller": ["packages/obs-controller/src/index.ts"],
      "@ans/overlay-engine": ["packages/overlay-engine/src/index.ts"],
      "@ans/broadcast-engine": ["packages/broadcast-engine/src/index.ts"],
      "@ans/tts-engine": ["packages/tts-engine/src/index.ts"],
      "@ans/media-engine": ["packages/media-engine/src/index.ts"],
      "@ans/media-engine/discovery": ["packages/media-engine/src/discovery-v2.ts"],
      "@ans/media-engine/workflow": ["packages/media-engine/src/workflow.ts"],
      "@ans/media-engine/video-upload": ["packages/media-engine/src/video-upload.ts"],
      "@ans/database": ["packages/database/src/index.ts"],
      "@ans/database/ai-presenters": ["packages/database/src/ai-presenters.ts"],
      "@ans/database/ai-staff": ["packages/database/src/ai-staff.ts"],
      "@ans/database/growth": ["packages/database/src/growth.ts"],
      "@ans/database/article-media": ["packages/database/src/article-media.ts"],
      "@ans/source-connectors": ["packages/source-connectors/src/index.ts"],
      "@ans/security/auth": ["packages/security/src/auth.ts"],
      "@ans/database/auth": ["packages/database/src/auth.ts"],
      "@ans/database/notifications": ["packages/database/src/notifications.ts"],
      "@ans/database/source-health": ["packages/database/src/source-health-store.ts"],
      "@ans/database/source-updates": ["packages/database/src/source-update-store.ts"]
    },
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx"
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", "tests/**/*.ts"],
  "exclude": ["**/dist/**", "node_modules"]
}
